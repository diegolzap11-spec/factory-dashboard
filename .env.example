# ============================================
# Variables de Entorno - Factory Dashboard
# ============================================

# ============================================
# OBLIGATORIAS
# ============================================

# Puerto del servidor (por defecto 3000)
PORT=3000

# Modo de ejecución: development o production
NODE_ENV=production

# ============================================
# OPCIONALES - Personalización
# ============================================

# Nombre del dashboard (mostrado en la interfaz)
APP_NAME=Flexo Impress

# Descripción del dashboard
APP_DESCRIPTION=Sistema de Gestión de Producción e Inventario
